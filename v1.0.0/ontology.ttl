<https://w3id.org/pmd/ont_pub_tmplt> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://w3id.org/pmd/ont_pub_tmplt/1.0.0> ;
                                      <http://purl.org/dc/terms/bibliographicCitation> "Doe J. (1960) Foo Ontology. Journal of Everything, 42(42), 3-42." ;
                                      <http://purl.org/dc/terms/created> "2023-12-15" ;
